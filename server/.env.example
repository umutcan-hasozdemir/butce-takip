# Bu dosyayı "server/.env" olarak kopyalayın ve değerleri doldurun.
# (server/.env asla GitHub'a yüklenmez — .gitignore'da)

# PostgreSQL bağlantı dizesi.
# Yerel test için örnek:  postgresql://postgres:SIFRE@localhost:5432/fintrack
# Neon (bulut) için Neon panelindeki "Connection string"i yapıştırın.
DATABASE_URL=postgresql://kullanici:sifre@host:5432/veritabani

# JWT imzalama anahtarı — uzun, rastgele bir değer girin.
JWT_SECRET=cok-gizli-rastgele-bir-anahtar-degistirin
